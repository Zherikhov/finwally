# Frontend configuration (Vite). Copy to `.env.local` and adjust as needed.

# Base URL of the backend REST API used by the app at runtime.
# Defaults to "/api", which the dev server proxies to the backend (see vite.config.ts)
# and which works in production when the SPA is served from the same origin.
# VITE_API_BASE_URL=/api

# Origin the dev server proxies "/api" requests to. Defaults to http://localhost:8080.
# VITE_BACKEND_ORIGIN=http://localhost:8080
